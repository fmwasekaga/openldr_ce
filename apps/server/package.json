    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "dependencies": {
    "@fastify/compress": "^9.0.0",
    "@fastify/static": "^9.1.3",
    "@openldr/bootstrap": "workspace:*",
    "@openldr/config": "workspace:*",
    "@openldr/core": "workspace:*",
    "@openldr/dashboards": "workspace:*",
    "@openldr/db": "workspace:*",
    "@openldr/dhis2": "workspace:*",
    "@openldr/forms": "workspace:*",
    "@openldr/marketplace": "workspace:*",
    "@openldr/report-designer": "workspace:*",
    "@openldr/reporting": "workspace:*",
    "@openldr/sync": "workspace:*",
    "@openldr/terminology": "workspace:*",
    "@openldr/workflows": "workspace:*",
    "adm-zip": "^0.5.16",
    "cpu-features": "^0.0.10",
    "fastify": "^5.2.0",
    "pdfkit": "^0.15.0",
    "ssh2": "^1.17.0",
    "zod": "^3.24.1"
