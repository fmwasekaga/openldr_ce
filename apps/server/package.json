{
  "name": "@openldr/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsup",
    "build:check": "tsup && node scripts/smoke.mjs",
    "dev": "node --watch dev.mjs",
