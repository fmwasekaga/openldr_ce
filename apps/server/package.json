  "devDependencies": {
    "@openldr/plugins": "workspace:*",
    "@openldr/ports": "workspace:*",
    "@types/adm-zip": "^0.5.7",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^10.7.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
