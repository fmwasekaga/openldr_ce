NODE_ENV=development
PORT=3000
LOG_LEVEL=info

AUTH_ADAPTER=keycloak
BLOB_ADAPTER=minio
EVENTING_ADAPTER=pg
TARGET_STORE_ADAPTER=pg

# Enable the dashboard raw-SQL widget escape hatch (Postgres warehouse only).
DASHBOARD_SQL_ENABLED=false

INTERNAL_DATABASE_URL=postgres://openldr:openldr@localhost:5433/openldr
TARGET_DATABASE_URL=postgres://openldr:openldr@localhost:5433/openldr_target

S3_ENDPOINT=http://localhost:9010
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=openldr
S3_FORCE_PATH_STYLE=true

OIDC_ISSUER_URL=http://localhost:8180/realms/openldr
OIDC_AUDIENCE=openldr-api
KEYCLOAK_ADMIN_CLIENT_ID=openldr-admin
KEYCLOAK_ADMIN_CLIENT_SECRET=openldr-admin-dev-secret

# --- Target store engine ---
# pg (default) writes the analytics warehouse to Postgres (TARGET_DATABASE_URL).
# mssql writes it to SQL Server (MSSQL_* below); start it with: docker compose --profile mssql up -d
TARGET_STORE_ADAPTER=pg
# MSSQL_HOST=127.0.0.1
# MSSQL_PORT=11433
# MSSQL_DATABASE=openldr
# MSSQL_USER=sa
# MSSQL_PASSWORD=Openldr_Local_2026!
# MSSQL_ENCRYPT=false
# MSSQL_TRUST_SERVER_CERT=true

# --- DHIS2 reporting target ---
# none (default) or dhis2. Start a local DHIS2: pnpm dhis2:seed && docker compose --profile dhis2 up -d
REPORTING_TARGET_ADAPTER=none
# The DHIS2 connection (base URL + credentials) is no longer set here — create a DHIS2
# Connector in the app (Settings ▸ Connectors). Secrets are encrypted at rest with
# SECRETS_ENCRYPTION_KEY (base64, 32 bytes — generate with: openssl rand -base64 32).
# SECRETS_ENCRYPTION_KEY=

# --- Marketplace ---
# Default remote registry seeded on first boot (when the registry table is empty).
MARKETPLACE_REGISTRY_URL=https://raw.githubusercontent.com/fmwasekaga/openldr-ce-marketplace/main
