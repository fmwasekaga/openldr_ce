# Copy to .env.prod and fill in. NEVER commit .env.prod (it is gitignored).
# Service hostnames (postgres / minio / keycloak) refer to docker-compose.prod.yml services.

# Public hostname nginx serves (used for the TLS cert + 80->443 redirect).
SERVER_NAME=localhost
PORT=3000
NODE_ENV=production

# Internal Postgres (the `postgres` service). The target (analytics warehouse) DB is the
# `openldr_target` database created by scripts/init-target-db.sql in the same instance.
INTERNAL_DATABASE_URL=postgres://openldr:openldr@postgres:5432/openldr
TARGET_DATABASE_URL=postgres://openldr:openldr@postgres:5432/openldr_target
POSTGRES_PASSWORD=openldr

# Blob storage (the `minio` service)
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=openldr
S3_FORCE_PATH_STYLE=true

# Auth (the `keycloak` service).
#
# REAL single-port SSO requires Keycloak served over the SAME HTTPS origin as the app —
# otherwise the browser blocks the OIDC discovery fetch as mixed content (HTTPS page →
# http://…:8180). That means proxying Keycloak under nginx (e.g. https://<host>/realms/…)
# + Keycloak proxy/hostname config + making the issuer reachable by the app container too.
# That integration is a documented follow-up beyond this single-port baseline.
#
# LOCAL DEMO (no real login): set NODE_ENV=development above and AUTH_DEV_BYPASS=true below
# (the app loads as a dev admin). Note AUTH_DEV_BYPASS is REJECTED when NODE_ENV=production.
OIDC_ISSUER_URL=http://host.docker.internal:8180/realms/openldr
OIDC_WEB_CLIENT_ID=openldr-web
# OIDC_AUDIENCE=
# AUTH_DEV_BYPASS=true   # requires NODE_ENV=development (forbidden in production)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Adapters / features
TARGET_STORE_ADAPTER=pg
REPORTING_TARGET_ADAPTER=none
MARKETPLACE_DEV_ALLOW_UNSIGNED=false
# MARKETPLACE_REGISTRY_DIR=/app/marketplace-registry
LOG_LEVEL=info
