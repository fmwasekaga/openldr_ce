# Copy to .env.prod and fill in. NEVER commit .env.prod (it is gitignored).
# Service hostnames (postgres / minio / keycloak) refer to docker-compose.prod.yml services.

# --- Gateway / public addressing (set by `pnpm run init`) ---
# The public hostname/IP the gateway serves. Used for the TLS cert, nginx server_name,
# the OIDC issuer, and Keycloak's advertised hostname.
SERVER_NAME=localhost
PUBLIC_ORIGIN=https://localhost
GATEWAY_HTTP_PORT=80
GATEWAY_HTTPS_PORT=443
TLS_MODE=self-signed
# LETSENCRYPT_EMAIL=ops@example.org   # required when TLS_MODE=letsencrypt

PORT=3000
NODE_ENV=production

# Internal Postgres (the `postgres` service). The target (analytics warehouse) DB is the
# `openldr_target` database created by scripts/init-target-db.sql in the same instance.
INTERNAL_DATABASE_URL=postgres://openldr:openldr@postgres:5432/openldr
TARGET_DATABASE_URL=postgres://openldr:openldr@postgres:5432/openldr_target
POSTGRES_PASSWORD=openldr

# Blob storage (the `minio` service)
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=openldr
S3_FORCE_PATH_STYLE=true

# --- Auth (Keycloak proxied under /auth on the same origin) ---
# Public issuer: used by the browser AND for issuer-claim validation.
OIDC_ISSUER_URL=https://localhost/auth/realms/openldr
# Internal (back-channel) JWKS: the app fetches signing keys over the docker network, so it
# needs no trust of the gateway's (possibly self-signed) cert. Issuer claim still validated
# against OIDC_ISSUER_URL above.
OIDC_INTERNAL_JWKS_URL=http://keycloak:8080/auth/realms/openldr/protocol/openid-connect/certs
# Internal (back-channel) realm base — sibling of OIDC_INTERNAL_JWKS_URL above. Server-side
# token/admin REST/JWKS calls use it instead of the public issuer (which, inside a container,
# resolves to the app itself). Issuer claim validation still uses OIDC_ISSUER_URL.
OIDC_INTERNAL_ISSUER_URL=http://keycloak:8080/auth/realms/openldr
OIDC_WEB_CLIENT_ID=openldr-web
# OIDC_AUDIENCE=
# AUTH_DEV_BYPASS=true   # requires NODE_ENV=development (forbidden in production)
# Keycloak's advertised external hostname (hostname v2). Must match PUBLIC_ORIGIN + /auth.
KC_HOSTNAME=https://localhost/auth
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
# Confidential client (service account) Keycloak uses for identity-admin REST calls (site
# enrollment, user management). Required for those actions to work.
KEYCLOAK_ADMIN_CLIENT_ID=openldr-admin
KEYCLOAK_ADMIN_CLIENT_SECRET=openldr-admin-dev-secret

# Run DB migrations on server startup (idempotent). Keep ON for this single-port
# deployment so a fresh Postgres self-migrates — otherwise the API 500s on a schema-less DB.
MIGRATE_ON_START=true

# Seed idempotent sample data (org/location/patient + bundled sample forms) on startup,
# after migration. ON so the demo comes up populated; set false for an empty production DB.
SEED_ON_START=true

# Adapters / features
TARGET_STORE_ADAPTER=pg
REPORTING_TARGET_ADAPTER=none

# External analytics target = Microsoft SQL Server (set TARGET_STORE_ADAPTER=mssql).
# Self-hosted only — no cloud/hosted databases. Supported: SQL Server 2017, 2019, 2022.
# MSSQL_HOST=your-sql-server-host
# MSSQL_PORT=1433
# MSSQL_DATABASE=openldr_target
# MSSQL_USER=openldr
# MSSQL_PASSWORD=change-me
# MSSQL_ENCRYPT=false
# MSSQL_TRUST_SERVER_CERT=true

# External analytics target = MySQL/MariaDB (set TARGET_STORE_ADAPTER=mysql).
# Self-hosted only — no cloud/hosted MySQL. Supported: MySQL 8.4 LTS, MariaDB 11.4 LTS.
# MYSQL_HOST=your-mysql-host
# MYSQL_PORT=3306
# MYSQL_DATABASE=openldr_target
# MYSQL_USER=openldr
# MYSQL_PASSWORD=change-me
# MYSQL_SSL=false

# Dashboard raw SQL is now a Settings → General feature flag (default off), not an env var.

# Encrypts connector/DHIS2 secrets at rest (required for those features).
# SECRETS_ENCRYPTION_KEY=  # base64 32 bytes: openssl rand -base64 32

# --- Marketplace ---
MARKETPLACE_DEV_ALLOW_UNSIGNED=false
# Default remote registry seeded on first boot (when the registry table is empty).
MARKETPLACE_REGISTRY_URL=https://raw.githubusercontent.com/Open-Laboratory-Data-Repository/marketplace/main
# MARKETPLACE_REGISTRY_DIR=/app/marketplace-registry
LOG_LEVEL=info
