auto-install-peers=true
strict-peer-dependencies=false

# Network resilience for slow/congested links (esp. Docker image builds that
# re-fetch the full store). Defaults (60s timeout, 2 retries, 16-way concurrency)
# abort on a starved connection; these give slow fetches room to complete.
fetch-timeout=600000
fetch-retries=5
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
network-concurrency=4
