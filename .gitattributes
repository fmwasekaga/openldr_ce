# Files consumed by Unix shells / containers must stay LF on every platform,
# otherwise a CRLF checkout on Windows breaks them (e.g. `#!/usr/bin/env sh\r`).
*.sh                       text eol=lf
deploy/nginx/*.template    text eol=lf
Dockerfile                 text eol=lf
*.dockerignore             text eol=lf
.dockerignore              text eol=lf
docker-compose*.yml        text eol=lf
.env.prod.example          text eol=lf

# Windows-native scripts stay CRLF.
*.ps1   text eol=crlf
*.cmd   text eol=crlf
*.bat   text eol=crlf

# Gzipped bundled fixtures are binary — never EOL-normalize (would corrupt the gzip stream).
*.json.gz binary

# Signed marketplace-bundle assets are byte-hashed at pack time (payload sha256 + UI sha256), so a
# CRLF checkout on Windows changes their bytes and breaks signature verification. Pin them so the
# bytes are identical on every platform: .wasm never touched, UI html normalized to LF (its canonical
# packed form). See packages/marketplace/src/bundle-fs.ts (verifyBundle).
*.wasm                       binary
reference-plugins/**/ui.html text eol=lf
