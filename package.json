{
  "name": "openldr",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@11.5.2",
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "turbo build",
    "build:check": "turbo build:check",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test": "turbo test",
    "depcruise": "depcruise packages apps --config .dependency-cruiser.cjs",
    "openldr": "tsx packages/cli/src/index.ts",
    "build:plugins": "node scripts/build-wasm-plugins.mjs",
    "make:whonet-sample": "node scripts/make-whonet-sample.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "dependency-cruiser": "^16.4.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
