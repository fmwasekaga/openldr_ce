{
  "name": "@openldr/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": { "openldr": "./dist/index.js" },
  "exports": { ".": "./src/index.ts" },
  "scripts": {
    "build": "tsup",
    "build:check": "tsup && node dist/index.js --help",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "echo \"no lint\""
  },
  "dependencies": {
    "@openldr/bootstrap": "workspace:*",
    "@openldr/marketplace": "workspace:*",
    "@openldr/plugins": "workspace:*",
    "@openldr/dhis2": "workspace:*",
    "@openldr/terminology": "workspace:*",
    "@openldr/config": "workspace:*",
    "@openldr/sync": "workspace:*",
    "@openldr/core": "workspace:*",
    "@openldr/db": "workspace:*",
    "@openldr/rbac": "workspace:*",
    "@openldr/dashboards": "workspace:*",
    "@openldr/fhir": "workspace:*",
    "@openldr/reporting": "workspace:*",
    "@openldr/forms": "workspace:*",
    "@openldr/report-designer": "workspace:*",
    "commander": "^12.1.0"
  },
  "devDependencies": { "kysely": "^0.28.17", "tsup": "^8.3.5", "typescript": "^5.7.2", "vitest": "^2.1.8" }
}
