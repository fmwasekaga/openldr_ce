  },
  "dependencies": {
    "@openldr/db": "workspace:*",
    "@openldr/reporting": "workspace:*",
    "kysely": "0.27.5",
    "zod": "3.24.0"
  },
  "devDependencies": {
    "pg-mem": "^3.0.14",
    "tsup": "8.3.5",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
